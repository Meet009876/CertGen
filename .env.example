# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/pdf_templates

# ── Asset Hosting ─────────────────────────────────────────────────────────────
# Supported values: "dropbox"
# To add a new provider see: app/services/asset_hosting/__init__.py
ASSET_HOST_PROVIDER=dropbox

# ── Dropbox — get App Key + App Secret from Dropbox App Console → Settings ────
# Run  python generate_refresh_token.py  once to get DROPBOX_REFRESH_TOKEN
DROPBOX_APP_KEY=your_app_key
DROPBOX_APP_SECRET=your_app_secret
DROPBOX_REFRESH_TOKEN=your_refresh_token

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=True
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Session auth ──────────────────────────────────────────────────────────────
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
